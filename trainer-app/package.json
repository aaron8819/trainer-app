{
    "name": "trainer-app",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "predev": "prisma generate",
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "test": "vitest run",
        "test:audit:matrix": "vitest run src/lib/audit/workout-audit/intent-matrix.test.ts src/lib/audit/workout-audit/next-session-intent-matrix.test.ts",
        "test:watch": "vitest --watch",
        "test:slow": "vitest run --passWithNoTests \"src/**/*.slow.test.ts\"",
        "test:fast": "vitest run src/lib/engine/selection-v2/ src/lib/engine/explainability/ src/lib/api/exercise-preferences.test.ts src/lib/api/template-session.test.ts",
        "prisma:generate": "prisma generate",
        "prisma:studio": "prisma studio",
        "db:seed": "tsx prisma/seed.ts",
        "postinstall": "prisma generate",
        "verify:exercise-library": "tsx scripts/verify-exercise-library.ts",
        "audit:workout": "tsx scripts/workout-audit.ts",
        "audit:split-sanity": "tsx scripts/audit-split-sanity.ts",
        "audit:week-close-handoff": "tsx scripts/audit-week-close-handoff.ts",
        "repair:week-close-handoff": "tsx scripts/repair-week-close-handoff.ts",
        "audit:sequencing": "tsx scripts/audit-sequencing.ts",
        "audit:accounting": "tsx scripts/audit-accounting-semantics.ts",
        "audit:week4-generation": "tsx scripts/audit-week4-generation.ts",
        "audit:exercise-classification": "tsx scripts/audit-exercise-classification.ts",
        "report:workout-week-snapshot-repair": "tsx scripts/report-workout-week-snapshot-repair.ts",
        "repair:workout-week-snapshot": "tsx scripts/repair-workout-week-snapshot.ts",
        "report:stimulus-coverage": "tsx scripts/report-stimulus-profile-coverage.ts",
        "report:weekly-volume-targets": "tsx scripts/report-weekly-volume-targets.ts",
        "verify:contracts": "tsx scripts/check-doc-runtime-contracts.ts",
        "verify:fast": "npm run lint && npx tsc --noEmit && npm run test:fast && npm run verify:contracts",
        "verify": "npm run verify:fast",
        "repair:exercise-library": "tsx scripts/repair-exercise-library.ts",
        "repair:exercise-library:apply": "tsx scripts/repair-exercise-library.ts --apply"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.3.0",
        "@prisma/client": "^7.3.0",
        "@supabase/ssr": "^0.8.0",
        "@supabase/supabase-js": "^2.93.3",
        "next": "16.1.6",
        "pg": "^8.18.0",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-hook-form": "^7.71.1",
        "recharts": "^3.7.0",
        "zod": "^4.3.6",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^20",
        "@types/pg": "^8.16.0",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^5.1.4",
        "@vitest/coverage-v8": "^4.0.18",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "happy-dom": "^20.6.1",
        "jsdom": "^28.1.0",
        "prisma": "^7.3.0",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "typescript": "^5",
        "vitest": "^4.0.18"
    }
}
